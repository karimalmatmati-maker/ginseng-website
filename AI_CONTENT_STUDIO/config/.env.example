# ============================================================
# AI Content Studio — Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.
# ============================================================

# OpenAI (required for AI analysis, SEO, hooks, Higgsfield)
OPENAI_API_KEY=sk-...

# ElevenLabs (optional — voice enhancement)
ELEVENLABS_API_KEY=

# Adobe Podcast Enhance Speech (optional)
# Also set api.adobe_podcast.enabled: true in settings.yaml
ADOBE_PODCAST_API_KEY=

# Google Gemini (optional — alternative to GPT-4)
GEMINI_API_KEY=
